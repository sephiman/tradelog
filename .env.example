# Externally-managed Postgres on a shared Docker network.
# The backend joins this network and resolves Postgres by DNS alias = DB_HOST.
SHARED_NETWORK_NAME=all_dockers

# Host port published for the frontend (external nginx terminates TLS in front of this).
FRONTEND_PORT=8088

# Host interface to bind the published port on (0.0.0.0 = anywhere, 127.0.0.1 = loopback only).
FRONTEND_BIND_ADDR=0.0.0.0

# Database — the operator must create this DB and user in Postgres before first run.
DB_HOST=postgres
DB_PORT=5432
DB_NAME=tradelog
DB_USERNAME=tradelog
DB_PASSWORD=change-me

# Cookie security. Set to false ONLY for local plain-HTTP development.
APP_COOKIE_SECURE=true

# Registration policy: open | invite-only | closed. Self-registration is the default.
REGISTRATION_MODE=open

# First-run admin bootstrap. Optional when REGISTRATION_MODE=open (first user can self-register);
# required otherwise.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Encryption key for exchange API credentials at rest (AES-GCM).
#   Base64-encoded 16/24/32-byte AES key. Generate one with:  openssl rand -base64 32
#   Required only once a data source with API credentials is saved. Keep it STABLE —
#   rotating it makes previously stored credentials undecryptable.
TRADELOG_CRYPTO_KEY=

# Nightly background sync of every active API source (optional — defaults shown).
#SYNC_SCHEDULE_ENABLED=true
#SYNC_SCHEDULE_CRON=0 0 4 * * *

# Background job materializing the automatic capital snapshots behind the Capital page and the
# ROI / capital-evolution panels. Hourly because day boundaries follow each user's time zone;
# re-runs are idempotent (optional — defaults shown).
#CAPITAL_SNAPSHOT_ENABLED=true
#CAPITAL_SNAPSHOT_CRON=0 20 * * * *

# JVM tuning (optional).
SPRING_PROFILES_ACTIVE=prod
JAVA_OPTS=
